# LimoFlight V4 — Environment Variables
# ⚠️  Copy to .env and NEVER commit to git — add .env to .gitignore

# ── Google APIs ───────────────────────────────────────────────────────────
VITE_GOOGLE_MAPS_KEY=AIzaSy...your_maps_key
VITE_MAP_ID=your_map_id
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ── Google Play Billing ───────────────────────────────────────────────────
GOOGLE_PLAY_CLIENT_ID=your_oauth_client_id
GOOGLE_PLAY_SECRET=your_oauth_secret
GOOGLE_PLAY_PUBLIC_KEY=MIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8A...

# ── WhatsApp Business Cloud API (Meta) ───────────────────────────────────
WA_PHONE_NUMBER_ID=123456789012345
WA_ACCESS_TOKEN=EAAGm...your_token
WA_VERIFY_TOKEN=limoflight_webhook_secret

# ── OpenTable API ─────────────────────────────────────────────────────────
OPENTABLE_CLIENT_ID=your_ot_client_id
OPENTABLE_SECRET=your_ot_secret
OPENTABLE_ACCESS_TOKEN=your_ot_access_token

# ── Payment Providers ─────────────────────────────────────────────────────
STRIPE_SECRET=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
PAYPAL_CLIENT_ID=AZD...
PAYPAL_SECRET=your_paypal_secret

# ── Database (PostgreSQL) ─────────────────────────────────────────────────
DATABASE_URL=postgresql://limoflight:password@localhost:5432/limoflight_db

# ── Security ──────────────────────────────────────────────────────────────
JWT_SECRET=your_256_bit_random_secret_here
ENCRYPTION_KEY=your_32_byte_aes_key_here_base64
ALLOWED_ORIGINS=https://limoflight.app,https://app.limoflight.com

# ── WebSocket Server ──────────────────────────────────────────────────────
VITE_WS_URL=wss://api.limoflight.app/live
PORT=3001

# ── App Config ────────────────────────────────────────────────────────────
VITE_API_URL=https://api.limoflight.app
VITE_APP_NAME=LimoFlight
NODE_ENV=production
